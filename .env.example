# local — можно передавать customer_tg_id без initData (отладка в браузере).
# production — только подписанный initData (Mini App / Telegram).
APP_ENV=local
# Telegram WebApp кнопка требует HTTPS.
# Для локальной отладки удобно использовать cloudflared:
#   cloudflared tunnel --url http://127.0.0.1:8000
# и затем поставить сюда выданный https://*.trycloudflare.com
BASE_URL=http://127.0.0.1:8000

# Uvicorn: по умолчанию 127.0.0.1:8000. Если в браузере «не открывается» при
# адресе localhost — откройте http://127.0.0.1:8000 (Windows часто шлёт localhost на IPv6).
# API_HOST=0.0.0.0 — слушать на всех интерфейсах (удобно с телефона в LAN).
# API_HOST=127.0.0.1
# API_PORT=8000

# SQLite for local development
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Telegram bot token от @BotFather (не коммитьте реальное значение).
BOT_TOKEN=

# Если Telegram API недоступен с сервера (таймауты/блокировки) — задайте прокси.
# Требования:
# - для SOCKS прокси нужен пакет aiohttp-socks (он есть в requirements.txt)
# Примеры:
# TELEGRAM_PROXY=http://host:port
# TELEGRAM_PROXY=socks5://user:password@host:port
TELEGRAM_PROXY=

# Куда слать уведомления оператору (для подсказок и deep link в боте).
OPERATOR_USERNAME=@your_operator_username
# Рекомендуется числовой chat_id (надёжнее). Узнать: команда /id в боте.
# Без OPERATOR_CHAT_ID бот не пришлёт оператору кнопку «Передан в доставку» после оплаты.
# OPERATOR_CHAT_ID=

# Проверка подписи Mini App initData (HMAC по документации Telegram).
# Пусто — используется BOT_TOKEN.
TELEGRAM_WEBAPP_SECRET=
# WEBAPP_INIT_MAX_AGE_SEC=86400

# Веб-панель оператора: /operator-panel (404, если пусто).
# Форма входа /operator-panel/login + cookie; либо HTTP Basic: логин operator, пароль = токен.
OPERATOR_PANEL_TOKEN=

# Доставщик: /delivery/login и API /delivery/...?token=
# Пусто — маршруты /delivery отдают 404.
# COURIER_API_TOKEN=
